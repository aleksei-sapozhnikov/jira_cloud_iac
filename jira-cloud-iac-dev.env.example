# -----------------------------------------------------------------------------
# Atlassian Forge CLI authentication
# -----------------------------------------------------------------------------

# Use an Atlassian API scoped token created for Forge.
FORGE_EMAIL=you@example.com
FORGE_API_TOKEN=replace-with-forge-api-token


# -----------------------------------------------------------------------------
# Jira Cloud REST API and Terraform provider authentication
# -----------------------------------------------------------------------------

# Jira Cloud base URL without a trailing slash.
ATLASSIAN_URL=https://your-site.atlassian.net

ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-with-jira-api-token


# -----------------------------------------------------------------------------
# Terraform input variables
# -----------------------------------------------------------------------------

# Jira account ID assigned as project lead to all demo spaces.
#
# After filling the Jira credentials above and starting the container, run:
#
#   node terraform/scripts/show-jira-identifiers.mjs
#
# Then replace the placeholder below with the printed Account ID.
TF_VAR_jira_project_lead_account_id=replace-with-jira-account-id
